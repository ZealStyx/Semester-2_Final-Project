        {
          "type": "WAIT",
          "delaySeconds": 0.35
        },
        {
          "type": "SHOW_SUBTITLE",
          "text": "The room resonates with a distant hum...",
          "duration": 2.8
        },
        {
          "type": "SET_FLAG",
          "flagName": "zone.sound.chain.completed",
          "value": true
        }
      ]
    },
