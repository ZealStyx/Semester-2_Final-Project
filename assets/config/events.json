        {
          "type": "SET_FLAG",
          "flagName": "zone.sound.entered",
          "value": true
        },
        {
          "type": "PLAY_SOUND",
          "soundPath": "audio/sfx/env/test.wav",
          "volume": 0.6
        },
        {
          "type": "FIRE_EVENT",
          "eventId": "zone-enter-sound-followup"
        }
      ]
    },
    {
      "id": "zone-enter-sound-followup",
      "displayName": "Sound Zone Followup",
      "repeatMode": "ONCE_PER_SESSION",
      "cooldownSeconds": 0.0,
