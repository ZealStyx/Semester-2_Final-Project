      "id": "debug-set-flag",
      "displayName": "Debug Flag Toggle",
      "repeatMode": "ONCE_PER_SESSION",
      "cooldownSeconds": 0.0,
      "actions": [
        {
          "type": "SET_FLAG",
          "flagName": "debug.event.flag",
          "value": true
        }
      ]
